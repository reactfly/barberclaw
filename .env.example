# Public frontend variables
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_public_key_here
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key_here

# Optional AI feature
GEMINI_API_KEY=your_gemini_api_key_here

# Public runtime endpoint aliases
# The app can also read PUBLIC_* aliases when needed.
PUBLIC_MAPBOX_TOKEN=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-side runtime
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_public_key_here
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key_here

# Server-side privileged key
# Prefer SUPABASE_SERVICE_ROLE_KEY. Keep these out of frontend env vars.
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_your_server_key_here
SUPABASE_SECRET_KEY=

# Optional server config
APP_TIMEZONE=America/Sao_Paulo
